    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/translations": "3.86.0",
    "graphql": "^16.11.0",
    "next": "15.4.11",
    "payload": "3.86.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "tsx": "^4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
