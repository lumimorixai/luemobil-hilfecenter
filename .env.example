# Datenbank:
#  - Entwicklung (ohne Docker):  file:./luemobil.db          (SQLite, Standard)
#  - Produktion (VPS):           postgres://user:pass@postgres:5432/luemobil
DATABASE_URI=file:./luemobil.db

# Payload-Secret: langen Zufallswert setzen, z. B. `openssl rand -hex 32`
PAYLOAD_SECRET=BITTE_AENDERN_openssl_rand_hex_32

# Erster Admin-User (wird vom Seed-Skript angelegt, falls nicht vorhanden)
ADMIN_EMAIL=jan.hedtfeld@lumimorix.de
ADMIN_PASSWORD=BITTE_AENDERN

# Öffentliche URL (Produktion, z. B. https://luemobil.swl-innovation.de)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Testphase: Seite aus Suchmaschinen heraushalten (noindex + robots.txt-Sperre).
# Zum echten Launch auf false setzen oder entfernen.
SITE_NOINDEX=true

# E-Mail-Benachrichtigung an Redakteur:innen (SMTP). Ohne SMTP_HOST ist der
# Versand deaktiviert (Mails landen dann nur in der Server-Konsole).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false          # true bei Port 465 (SSL), sonst false (STARTTLS)
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_ADDRESS=no-reply@swl-innovation.de
EMAIL_FROM_NAME=LüMobil Hilfecenter

# Jira-Anbindung: Sobald ein bekannter Fehler den Status „Gemeldet" erhält,
# wird automatisch EIN Jira-Ticket angelegt und die Ticket-ID (z. B. LUEM-42)
# im Datensatz gespeichert. Solange nicht alle vier Pflichtwerte gesetzt sind,
# bleibt die Anbindung inaktiv (keine Tickets werden erzeugt).
JIRA_BASE_URL=                       # z. B. https://stadtwerke-luebeck.atlassian.net
JIRA_EMAIL=                          # E-Mail des Atlassian-Kontos zum API-Token
JIRA_API_TOKEN=                      # Atlassian-API-Token (Jira Cloud)
JIRA_PROJECT_KEY=                    # Ziel-Projekt, z. B. LUEM
JIRA_ISSUE_TYPE=Bug                  # Vorgangstyp (Standard: Bug)
JIRA_SET_PRIORITY=false              # true, um Schweregrad → Priorität zu senden
