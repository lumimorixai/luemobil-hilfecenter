# Datenbank:
#  - Entwicklung (ohne Docker):  file:./luemobil.db          (SQLite, Standard)
#  - Produktion (VPS):           postgres://user:pass@postgres:5432/luemobil
DATABASE_URI=file:./luemobil.db

# Payload-Secret: langen Zufallswert setzen, z. B. `openssl rand -hex 32`
PAYLOAD_SECRET=BITTE_AENDERN_openssl_rand_hex_32

# Erster Admin-User (wird vom Seed-Skript angelegt, falls nicht vorhanden)
ADMIN_EMAIL=jan.hedtfeld@lumimorix.de
ADMIN_PASSWORD=BITTE_AENDERN

# Öffentliche URL (Produktion, z. B. https://hilfe.luemobil.de)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
